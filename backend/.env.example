# Backend — Cloudflare Workers + Hyperdrive
# These variables are for LOCAL DEV only (wrangler dev reads .dev.vars, not .env.example)
# For production, use: wrangler secret put <KEY>

# ── Local Dev (.dev.vars) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/campuslink
JWT_SECRET=your_super_secret_jwt_key_change_this
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
CLIENT_URL=http://localhost:5173
ALLOWED_DOMAINS=.edu

# ── Production (set via CLI) ──────────────────────────────────────────────────
# npx wrangler secret put JWT_SECRET
# npx wrangler secret put SUPABASE_URL
# npx wrangler secret put SUPABASE_ANON_KEY

# ── wrangler.toml (non-secret vars) ──────────────────────────────────────────
# CLIENT_URL = "https://campuslink.pages.dev"  (set in wrangler.toml [vars])
# NODE_ENV = "production"                       (set in wrangler.toml [vars])

# ── NOTE: PORT is NOT used in Cloudflare Workers ─────────────────────────────
# wrangler dev runs on http://localhost:8787 by default
